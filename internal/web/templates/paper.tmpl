{{define "title"}}{{if .Detail.Title}}{{.Detail.Title}}{{else}}论文{{end}} — ScholarFlow{{end}}
{{define "content"}}
{{$ev := .EvidenceByClaim}}
{{$figs := .FiguresByClaim}}
<p><a href="/">← 返回论文集</a></p>
<h1>{{if .Detail.Title}}{{.Detail.Title}}{{else}}{{.Detail.UploadedFilename}}{{end}}</h1>
<p class="subtitle">
  {{range $i, $a := .Detail.Authors}}{{if $i}}, {{end}}{{$a.DisplayName}}{{end}}
  {{if .Detail.PublicationYear}} · {{.Detail.PublicationYear}}{{end}}
  {{if .Detail.DOI}} · {{.Detail.DOI}}{{end}}
</p>
{{if .Detail.Card}}
  {{$card := .Detail.Card}}
  {{with $card.Background}}<section><h2>背景</h2><p>{{.}}{{template "sidenotes" index $ev "background"}}{{template "figurenotes" index $figs "background"}}</p></section>{{end}}
  {{with $card.Problem}}<section><h2>问题</h2><p>{{.}}{{template "sidenotes" index $ev "problem"}}{{template "figurenotes" index $figs "problem"}}</p></section>{{end}}
  {{with $card.Method}}<section><h2>方法</h2><p>{{.}}{{template "sidenotes" index $ev "method"}}{{template "figurenotes" index $figs "method"}}</p></section>{{end}}
  {{with $card.Implementation}}<section><h2>实现</h2><p>{{.}}{{template "sidenotes" index $ev "implementation"}}{{template "figurenotes" index $figs "implementation"}}</p></section>{{end}}
  {{if $card.Results}}<section><h2>结果</h2>{{template "claimlist" dict "Items" $card.Results "Field" "results" "Ev" $ev "Figs" $figs}}</section>{{end}}
  {{if $card.Benchmarks}}<section><h2>评测基准</h2>{{template "claimlist" dict "Items" $card.Benchmarks "Field" "benchmarks" "Ev" $ev "Figs" $figs}}</section>{{end}}
  {{if $card.Baselines}}<section><h2>对比基线</h2>{{template "claimlist" dict "Items" $card.Baselines "Field" "baselines" "Ev" $ev "Figs" $figs}}</section>{{end}}
  {{if or $card.CodeLinks $card.DataLinks}}<section><h2>链接</h2><ul class="card-list">{{range $card.CodeLinks}}<li><a href="{{.}}">{{.}}</a></li>{{end}}{{range $card.DataLinks}}<li><a href="{{.}}">{{.}}</a></li>{{end}}</ul></section>{{end}}
{{else}}
  <p class="notice">阅读尚未完成（状态：{{.Detail.Status}}）。</p>
{{end}}
{{end}}

{{/* claimlist renders a list field, attaching each bullet's sidenotes and figure
     callouts at "field#N", plus any unindexed "field" notes after the list. */}}
{{define "claimlist"}}<ul class="card-list">
{{$field := .Field}}{{$ev := .Ev}}{{$figs := .Figs}}
{{range $i, $item := .Items}}<li>{{$item}}{{$key := printf "%s#%d" $field $i}}{{template "sidenotes" index $ev $key}}{{template "figurenotes" index $figs $key}}</li>
{{end}}</ul>{{$rest := index $ev $field}}{{$restFigs := index $figs $field}}{{if or $rest $restFigs}}<p class="claim-extra">{{template "sidenotes" $rest}}{{template "figurenotes" $restFigs}}</p>{{end}}{{end}}

{{define "sidenotes"}}{{range $i, $e := .}}{{if $i}}<sup class="sidenote-comma">,</sup>{{end}}<label for="{{$e.DOMID}}" class="margin-toggle sidenote-number"></label><input type="checkbox" id="{{$e.DOMID}}" class="margin-toggle"/><span class="sidenote">{{if $e.Page}}[p.{{$e.Page}}] {{else if $e.SectionID}}[§{{$e.SectionID}}] {{end}}{{$e.Snippet}}</span>{{end}}{{end}}

{{define "figurenotes"}}{{range $f := .}}<label for="{{$f.DOMID}}" class="margin-toggle figure-toggle">&#8853;</label><input type="checkbox" id="{{$f.DOMID}}" class="margin-toggle"/><span class="marginnote figure-callout"><strong>{{$f.Label}}</strong>{{if $f.Page}}（第 {{$f.Page}} 页）{{end}}{{if $f.Caption}}：{{$f.Caption}}{{end}}</span>{{end}}{{end}}
